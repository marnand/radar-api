{
  "name": "radar-api",
  "version": "1.0.0",
  "description": "Radar iKasa - Módulo de Aquisição de CNPJs",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node dist/db/migrate.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/sensible": "^6.0.0",
    "bcryptjs": "^3.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.8.5",
    "node-cron": "^3.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0"
  }
}
